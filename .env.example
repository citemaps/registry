# Vercel KV (Upstash Redis) — provisioned via Vercel project's
# Storage tab. Vercel auto-populates these env vars in the
# project, so the local .env.local just needs them for `next dev`.
#
# To set up:
#   1. Vercel dashboard → project → Storage → Create → KV
#   2. After provisioning, Vercel populates the deployment env;
#      pull locally via `vercel env pull .env.local`.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Optional — if set, the submit route requires this token in the
# Authorization header. Useful for v0 to gate Studio submissions
# without exposing the API publicly until basic spam protection
# matures. Studio sends it via env (CITEMAPS_REGISTRY_TOKEN); the
# value lives in both Vercel projects' env. Leave empty for
# fully-open submissions.
REGISTRY_SUBMIT_TOKEN=
